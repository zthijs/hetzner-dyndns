{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "maxSize": 2000000,
    "includes": [
      "**",
      "!node_modules",
      "!dist",
      "!build"
    ]
  },
  "formatter": {
    "enabled": true,
    "bracketSpacing": true,
    "expand": "auto",
    "formatWithErrors": false,
    "useEditorconfig": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "domains": {
      "project": "recommended"
    },
    "rules": {
      "complexity": {
        "noForEach": "off",
        "useOptionalChain": "off",
        "noUselessSwitchCase": "off",
        "noCommaOperator": "error",
        "useNumericLiterals": "error",
        "noArguments": "error"
      },
      "performance": {
        "noAccumulatingSpread": "off"
      },
      "style": {
        "useEnumInitializers": "off",
        "useDefaultSwitchClause": "error",
        "useFilenamingConvention": {
          "level": "warn",
          "options": {
            "requireAscii": true,
            "strictCase": false,
            "filenameCases": [
              "kebab-case"
            ]
          }
        },
        "useLiteralEnumMembers": "error",
        "useNodejsImportProtocol": "error",
        "useAsConstAssertion": "error",
        "useSelfClosingElements": "error",
        "useConst": "error",
        "useSingleVarDeclarator": "error",
        "noUnusedTemplateLiteral": "error",
        "useNumberNamespace": "error",
        "noInferrableTypes": "error",
        "useExponentiationOperator": "error",
        "useTemplate": "error",
        "noParameterAssign": "off",
        "noNonNullAssertion": "error",
        "useDefaultParameterLast": "error",
        "useImportType": "error",
        "useExportType": "error",
        "noUselessElse": "error",
        "useShorthandFunctionType": "error"
      },
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": {
          "level": "warn",
          "options": {
            "ignoreRestSiblings": true
          }
        }
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [
                ":NODE:",
                ":BUN:"
              ],
              [
                ":URL:",
                ":PATH:",
                ":PACKAGE_WITH_PROTOCOL:",
                ":PACKAGE:",
                ":ALIAS:"
              ]
            ]
          }
        }
      }
    }
  },
  "javascript": {
    "assist": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true,
      "gritMetavariables": true
    },
    "formatter": {
      "enabled": true,
      "quoteStyle": "single",
      "quoteProperties": "asNeeded",
      "semicolons": "always",
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100,
      "lineEnding": "lf",
      "bracketSpacing": true,
      "expand": "auto",
      "operatorLinebreak": "after",
      "trailingCommas": "all",
      "arrowParentheses": "asNeeded"
    }
  },
  "json": {
    "assist": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "bracketSpacing": true,
      "expand": "always",
      "lineEnding": "lf",
      "trailingCommas": "none",
      "indentWidth": 2,
      "lineWidth": 100
    },
    "parser": {
      "allowComments": true,
      "allowTrailingCommas": true
    }
  },
  "overrides": [
    {
      "includes": [
        "src/lib/hetzner/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noConfusingVoidType": "off",
            "useIterableCallbackReturn": "off"
          },
          "style": {
            "noNonNullAssertion": "off",
            "useDefaultSwitchClause": "off",
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ]
}
