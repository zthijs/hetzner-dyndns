{
  "name": "@zthijs/hetzner-dyndns",
  "module": "src/index.ts",
  "type": "module",
  "author": {
    "name": "zthijs"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "NODE_ENV=development bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "generate:hetzner": "openapi-ts",
    "lint": "biome check",
    "format-n-lint": "biome format && biome check",
    "format-n-lint:fix": "biome format --fix && biome check --fix",
    "format-n-lint:ci": "biome ci",
    "prepare": "husky"
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@hey-api/openapi-ts": "0.97.1",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  }
}
